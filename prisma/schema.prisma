generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum TradeSide {
  LONG
  SHORT
}

enum TradeStatus {
  RUNNING
  PROFIT
  LOSS
  BREAKEVEN
}

enum AccountType {
  PERSONAL
  FUNDED
  DEMO
  PROP_FIRM
}

enum AccountStatus {
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  ARCHIVED
}

enum LossType {
  PERCENTAGE
  FIXED
}

model TradingAccount {
  id                 Int           @id @default(autoincrement())
  userId             String
  name               String
  broker             String?
  platform           String?
  startingBalance    Float
  currentBalance     Float
  currency           String        @default("USD")
  accountType        AccountType
  status             AccountStatus @default(ACTIVE)
  profitTarget       Float?
  maxDailyLoss       Float?
  maxOverallDrawdown Float?
  maxDailyLossType   LossType?
  maxDrawdownType    LossType?
  icon               String?
  color              String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  archivedAt         DateTime?
  trades             Trade[]
  riskProfile        TradingRiskProfile?

  @@index([userId])
  @@index([status])
}

model TradingRiskProfile {
  id                   Int            @id @default(autoincrement())
  accountId            Int            @unique
  userId               String
  phase1TargetPct      Float?
  phase2TargetPct      Float?
  personalDailyLossPct Float?
  customRules          String[]       @default([])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  account              TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Trade {
  id             Int           @id @default(autoincrement())
  userId         String
  accountId      Int?
  source         String?
  externalId     String?
  tradeDate      DateTime
  symbol         String
  side           TradeSide
  entryPrice     Float?
  exitPrice      Float?
  stopLoss       Float?
  takeProfit     Float?
  quantity       Float         @default(1)
  riskUsd        Float
  resultUsd      Float
  status         TradeStatus    @default(RUNNING)
  grade          String?
  session        String?
  setup          String?
  strategy       String?
  analysis       Json?
  emotions       String?
  notes          String?
  screenshots    String[]      @default([])
  createdAt      DateTime      @default(now())
  journalEntryId Int?
  account        TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([tradeDate])
  @@index([symbol])
  @@index([side])
  @@index([accountId])
  @@index([journalEntryId])
  @@index([userId, source, externalId])
}

model JournalEntry {
  id               Int     @id @default(autoincrement())
  userId           String
  entryDate        DateTime
  title            String
  content          String
  imageUrl         String?
  mood             String?
  tags             String?
  strategyTags     String?
  preTradeMood     String?
  executionQuality String?
  score            Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  trades           Trade[]

  @@index([entryDate])
  @@index([title])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  image        String?
  authProvider AuthProvider @default(EMAIL)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
